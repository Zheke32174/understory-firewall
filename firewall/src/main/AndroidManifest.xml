<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Suite capability registry permission. ONE shared signature-level
      name declared identically in every suite app (first-installed
      definition wins by Android semantics; identical same-cert
      declarations keep that safe). CAPS_WRITE is defined but requested
      by no app — a permanently locked write gate for the provider.
    -->
    <permission
        android:name="com.understory.suite.CAPS"
        android:protectionLevel="signature" />
    <permission
        android:name="com.understory.suite.CAPS_WRITE"
        android:protectionLevel="signature" />
    <uses-permission android:name="com.understory.suite.CAPS" />

    <!--
      WRITE_SECURE_SETTINGS — declared so the ADB-grant flow has a
      target. This is signature-level: the runtime UI cannot grant it,
      and the manifest declaration alone does NOT confer the right.
      The user grants it once from a connected machine via
      `adb shell pm grant com.understory.firewall
       android.permission.WRITE_SECURE_SETTINGS`.
      Once granted, PrivateDnsApplier.apply() can set Settings.Global's
      private_dns_mode + private_dns_specifier directly so the user
      doesn't have to paste the DoT hostname into Android Settings.
      Without the grant, the DnsPrefsScreen falls back to the existing
      deep-link flow (unchanged behavior for users who don't run ADB).
    -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!--
      PACKAGE_USAGE_STATS — special app access ("Usage access"), granted by
      the user in Settings, never at runtime. Powers the opt-in Traffic-by-App
      screen (NetworkStatsManager + foreground-window cross-reference). The
      screen degrades to a "grant Usage access" affordance without it — the
      permission is NEVER required for the app to function. Same special-access
      pattern as WRITE_SECURE_SETTINGS above.
    -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!--
      Understory Net Audit is an observe/advise/route egress dashboard
      (design-v2/firewall.md §0). In the default Companion mode it does NOT
      own the VpnService slot and gates no traffic — it reads posture and
      routes to the OS's own controls. Packet-level blocking exists ONLY in
      the opt-in, default-off Standalone mode, which refuses to start while
      any other VPN holds the slot (VpnSlotProbe guardrail, §4). Permissions
      are explicit and narrowly justified:
        INTERNET — the explicit-tap egress/DNS canaries (§5.6); also the
                            Standalone engine's protectedSocket() fallbacks.
        ACCESS_NETWORK_STATE — read the VPN-slot / tunnel posture (the
                            guardrail veto + Tunnel Posture read-model).
        FOREGROUND_SERVICE / FOREGROUND_SERVICE_SPECIAL_USE — only the
                            Standalone engine's VpnService needs an FGS; it
                            runs solely while Standalone is armed.
        POST_NOTIFICATIONS — the persistent notification the Standalone
                            engine shows while it is actively blocking.
        QUERY_ALL_PACKAGES — enumerate installed apps for the Restrict /
                            Traffic / Audit surfaces. Genuinely needed for
                            this app's purpose; only suite app that requests
                            it. (Antivirus and mdm-local will also use it.)
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!--
      RECEIVE_BOOT_COMPLETED — the opt-in Posture Watch (PostureWatchReceiver)
      re-arms its inexact AlarmManager re-check after a reboot or an app update,
      since alarms don't survive either. Normal-protection, no runtime prompt.
      The receiver no-ops entirely unless the user has enabled the watch.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
      OPTIONAL ELEVATION (Shizuku). The suite is rootless by default; this
      permission is the one the Shizuku manager checks when this app requests
      access. It confers NOTHING on its own — the powers only light up if the
      user has installed Shizuku and explicitly granted this app. When neither
      Shizuku nor Dhizuku is present/granted, every elevated control degrades
      to the existing OS deep-link (see :elevation README). Dhizuku needs no
      per-app manifest copy: its API AAR merges its own
      com.rosan.dhizuku.permission.API uses-permission + <queries> block.
    -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />
    <!-- Other network surfaces still stripped. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" tools:node="remove" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" tools:node="remove" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" tools:node="remove" />
    <!-- SMS / MMS -->
    <uses-permission android:name="android.permission.SEND_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.WRITE_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.RECEIVE_MMS" tools:node="remove" />
    <uses-permission android:name="android.permission.RECEIVE_WAP_PUSH" tools:node="remove" />
    <!-- Cellular / telephony -->
    <uses-permission android:name="android.permission.CALL_PHONE" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_PRECISE_PHONE_STATE" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" tools:node="remove" />
    <uses-permission android:name="android.permission.WRITE_CALL_LOG" tools:node="remove" />
    <uses-permission android:name="android.permission.PROCESS_OUTGOING_CALLS" tools:node="remove" />
    <!-- Satellite -->
    <uses-permission android:name="android.permission.SATELLITE_COMMUNICATION" tools:node="remove" />
    <!-- Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH" tools:node="remove" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" tools:node="remove" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" tools:node="remove" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" tools:node="remove" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" tools:node="remove" />
    <!-- NFC -->
    <uses-permission android:name="android.permission.NFC" tools:node="remove" />
    <uses-permission android:name="android.permission.NFC_TRANSACTION_EVENT" tools:node="remove" />
    <!--
      Location — FINE + COARSE are *granted* for the opt-in Mock Location tool
      (location-privacy: LocationManager test-provider feed). They back the
      addTestProvider/setTestProviderLocation calls, which require the app to
      hold location permission in addition to the OS mock-location slot. Nothing
      runs until the user picks a point and taps Start. BACKGROUND_LOCATION stays
      stripped — the mock feed is foreground-service-scoped only.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" tools:node="remove" />
    <!-- Audio -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" tools:node="remove" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" tools:node="remove" />
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_OUTPUT" tools:node="remove" />
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_HOTWORD" tools:node="remove" />
    <uses-permission android:name="android.permission.CAPTURE_MEDIA_OUTPUT" tools:node="remove" />
    <uses-permission android:name="android.permission.CAPTURE_VOICE_COMMUNICATION_OUTPUT" tools:node="remove" />
    <uses-permission android:name="android.permission.BIND_VOICE_INTERACTION" tools:node="remove" />
    <uses-permission android:name="android.permission.BIND_TEXT_SERVICE" tools:node="remove" />
    <!-- Camera -->
    <uses-permission android:name="android.permission.CAMERA" tools:node="remove" />
    <uses-permission android:name="android.permission.BACKGROUND_CAMERA" tools:node="remove" />
    <uses-permission android:name="android.permission.SYSTEM_CAMERA" tools:node="remove" />
    <!-- Biometrics -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" tools:node="remove" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" tools:node="remove" />
    <!-- Storage / media -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" tools:node="remove" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" tools:node="remove" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" tools:node="remove" />
    <!--
      Notifications / overlays. POST_NOTIFICATIONS is *granted* above (line
      35) — VpnService needs it for the persistent foreground notification.
      Don't strip it here even though we strip the rest of this category.
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" tools:node="remove" />
    <!--
      Package query / install. QUERY_ALL_PACKAGES is *granted* above (line
      36) — the per-app rules UI legitimately needs to enumerate installed
      packages. Don't strip it here.
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" tools:node="remove" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" tools:node="remove" />
    <!-- Service binds -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" tools:node="remove" />
    <uses-permission android:name="android.permission.BIND_DEVICE_ADMIN" tools:node="remove" />
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" tools:node="remove" />
    <uses-permission android:name="android.permission.BIND_QUICK_SETTINGS_TILE" tools:node="remove" />
    <!-- Sensors -->
    <uses-permission android:name="android.permission.BODY_SENSORS" tools:node="remove" />
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" tools:node="remove" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" tools:node="remove" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" tools:node="remove" />
    <!-- VoIP -->
    <uses-permission android:name="android.permission.USE_SIP" tools:node="remove" />
    <!-- Other -->
    <uses-permission android:name="android.permission.READ_CONTACTS" tools:node="remove" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" tools:node="remove" />
    <uses-permission android:name="android.permission.GET_ACCOUNTS" tools:node="remove" />
    <uses-permission android:name="android.permission.READ_CALENDAR" tools:node="remove" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" tools:node="remove" />

    <queries>
        <!-- Suite siblings — needed for SuiteAttestation cross-verification. -->
        <package android:name="com.understory.passgen" />
        <package android:name="com.understory.aegis" />
        <package android:name="com.understory.backups" />
        <package android:name="com.understory.browser" />
        <package android:name="com.understory.antivirus" />
        <package android:name="com.understory.vaultfolder" />
        <!--
          Tailscale — attribution only (name the incumbent in copy + read
          installed/version for Tunnel Posture). The CM TRANSPORT_VPN veto
          NEVER depends on this; if the package is invisible we degrade to
          "another app" (design-v2/firewall.md §4/§5.1, SUITE #9).
        -->
        <package android:name="com.tailscale.ipn" />
        <!--
          Common consumer VPNs — cosmetic, for nicer incumbent copy only.
          The guardrail's veto is package-independent.
        -->
        <package android:name="com.wireguard.android" />
        <package android:name="org.mullvad.mullvadvpn" />
        <package android:name="net.openvpn.openvpn" />
        <package android:name="ch.protonvpn.android" />
        <!-- Lucky Patcher / Xposed / Magisk — same Tamper.luckyPatcherInstalled lookups. -->
        <package android:name="com.chelpus.lackypatch" />
        <package android:name="com.dimonvideo.luckypatcher" />
        <package android:name="com.forpda.lp" />
        <package android:name="com.android.vending.billing.InAppBillingService.LUCK" />
        <package android:name="com.android.vending.billing.InAppBillingService.LACK" />
        <package android:name="ru.aaaaaaac.luckypatcher" />
        <package android:name="uret.jasi2169.patcher" />
        <package android:name="zone.jasi2169.uretpatcher" />
        <package android:name="ru.luckypatchers.luckypatcherinstaller" />
        <package android:name="de.robv.android.xposed.installer" />
        <package android:name="org.meowcat.edxposed.manager" />
        <package android:name="org.lsposed.manager" />
        <package android:name="io.github.lsposed.manager" />
        <package android:name="com.topjohnwu.magisk" />
        <package android:name="io.github.huskydg.magisk" />
        <package android:name="com.kingoapp.apk" />
        <package android:name="com.koushikdutta.rommanager" />
        <package android:name="eu.chainfire.supersu" />
    </queries>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.Firewall"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:extractNativeLibs="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:supportsRtl="true">

        <!--
          Activity-isolation set (excludeFromRecents/singleTask) kept for the
          suite security posture. Orientation is sensor-portrait (SUITE #9): a
          rigid portrait lock fought accessibility rotation without adding
          protection; the FLAG_SECURE + recents-off hardening is what matters.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:resizeableActivity="false"
            android:screenOrientation="sensorPortrait"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode"
            android:theme="@style/Theme.Firewall">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          VpnService — the WALLED-OFF Standalone engine (design-v2/firewall.md
          §3). It only ever establishes a session when the user has opted into
          Standalone mode, armed the engine, AND the VpnSlotProbe guardrail
          confirms no other VPN holds the slot. On a Tailscale device that
          state is unreachable, so this service stays dormant and the app is a
          pure Companion egress dashboard. A registered-but-dormant VpnService
          does NOT hold the slot (holding requires an established session), so
          its manifest presence is doctrine-safe.

          exported="true" is the platform contract for the android.net.VpnService
          intent-filter (the system binds after user consent); BIND_VPN_SERVICE
          is signature-level so only the OS can bind. foregroundServiceType=
          "specialUse" with PROPERTY_SPECIAL_USE_FGS_SUBTYPE="vpn" is the
          correct type for a non-system VPN app on Android 14+.
        -->
        <service
            android:name=".FirewallVpnService"
            android:exported="true"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn" />
        </service>

        <!--
          Suite capability beacon. Read-only single-row provider that
          attests this app's package + version to peers. Signature-locked
          so only same-cert suite apps can query.
        -->
        <provider
            android:name=".SuiteCapsProvider"
            android:authorities="${applicationId}.suitecaps"
            android:exported="true"
            android:readPermission="com.understory.suite.CAPS"
            android:writePermission="com.understory.suite.CAPS_WRITE"
            android:grantUriPermissions="false" />

        <!--
          OPTIONAL ELEVATION (Shizuku). The provider through which the Shizuku
          manager hands this app a binder after the user grants access. Present
          only to opt this app into Shizuku; it is inert unless Shizuku is
          installed and the user grants this app. The shell UserService
          (com.understory.elevation.shizuku.ShellUserService) is instantiated
          across the process boundary by Shizuku from the UserServiceArgs the
          broker builds, so it is intentionally NOT declared here (see the
          :elevation README + consumer-rules.pro that keeps it from R8).
        -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!--
          Posture Watch receiver (design-v2/firewall.md §5.4 background). Handles:
            - the app-private POSTURE_WATCH_CHECK alarm (a scheduled re-check), and
            - BOOT_COMPLETED / MY_PACKAGE_REPLACED, to re-arm the alarm after a
              reboot or app update.
          exported="false": only our own AlarmManager PendingIntent and the
          system's protected boot/replace broadcasts reach it. The receiver is
          inert unless the user has opted into the watch; a stale alarm delivered
          after the user turns it off is dropped without rescheduling.
        -->
        <receiver
            android:name=".PostureWatchReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
          ARP-guard watch receiver. Handles the app-private ARP_GUARD_CHECK alarm
          (a scheduled neighbor-table re-scan) plus BOOT_COMPLETED / MY_PACKAGE_REPLACED
          to re-arm the inexact AlarmManager alarm after a reboot or update (alarms
          don't survive either). exported="false": only our own PendingIntent and the
          system's protected boot/replace broadcasts reach it. Inert unless the user
          enabled the watch; a stale alarm after disabling is dropped without rescheduling.
        -->
        <receiver
            android:name=".ArpGuardWatchReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
          Mock-location foreground service (location-privacy tool, NOT a VPN). Keeps
          the LocationManager test-provider feed alive while the user has a fake point
          active, with a persistent notification + Stop action. exported=false: only
          our own MockLocationScreen starts/stops it. specialUse FGS type with the
          PROPERTY_SPECIAL_USE_FGS_SUBTYPE="mock_location" declaration required on
          Android 14+. Holds no network slot.
        -->
        <service
            android:name=".MockLocationService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="mock_location" />
        </service>

    </application>

</manifest>
